[node name="Track" type="Area2D" parent="." unique_id=1293518330 node_paths=PackedStringArray("nametag")]
position = Vector2(86, 200)
script = ExtResource("3_mts1m")
faith = Color(0.9881224, 1, 0.7533076, 1)
description = "You step up to the starting block and settle in position. You feel comfortable in your armor, your muscles tens in anticipation of the comand. GO!!! Calls captain Syx and your legs spring into action. This is simple without a sword swinging at your hip. You lean your weight forward and drive your feet into the ground, bring one knee back up to catch yourself, and stomp that foot to the earth. Your armps pump opposite your legs and you regain your upright posture as you reach your maximum speed. You blow past the finish line and drive your right heel into the dirt you then slow to a stop in a few confident strides."
nametag = NodePath("NameTag")
metadata/_custom_type_script = "uid://b8ubm11tkmok4"

